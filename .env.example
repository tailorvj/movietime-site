# Public URL where this site is served (no trailing slash).
# Used to build access links in transactional emails.
APP_URL=http://localhost:8888

# HMAC secret for signing the session cookie. REQUIRED in production.
COOKIE_SECRET=change-me-in-production

# Session cookie lifetime in seconds.
SESSION_TTL_SECONDS=60

# Resend transactional email. Without this, background mail logs the URL.
# RESEND_API_KEY=

EMAIL_FROM="Gett Movie <onboarding@resend.dev>"

# Salt for hashing emails before storage in Netlify Blobs.
EMAIL_HASH_SALT=change-me-too

# Rate limits for POST /api/request-access. Set to 0 to disable.
REQUEST_ACCESS_IP_LIMIT_PER_DAY=5
REQUEST_ACCESS_EMAIL_LIMIT_PER_HOUR=3

# --- Browser (PUBLIC_ prefix, Astro) ---------------------------------------

# Vimeo numeric video id (domain allowlist in Vimeo dashboard).
PUBLIC_VIMEO_VIDEO_ID=163720263

# Contact email on the geo-unavailable page.
PUBLIC_CONTACT_EMAIL=contact@example.com
