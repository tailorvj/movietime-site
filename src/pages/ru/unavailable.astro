---
export const prerender = true
import BaseLayout from '../../layouts/BaseLayout.astro'
import { messages } from '../../i18n'

const locale = 'ru'
const t = messages(locale)
const contact = import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'contact@example.com'
---

<BaseLayout locale={locale} title={t.unavailable.title}>
  <h1 class="text-2xl font-semibold">{t.unavailable.title}</h1>
  <p class="mt-3 text-zinc-300">{t.unavailable.body}</p>
  <p class="mt-6">
    <a
      href={`mailto:${contact}`}
      class="inline-block rounded-md bg-emerald-400 px-4 py-2 font-semibold text-black hover:bg-emerald-300"
    >
      {t.unavailable.contact}
    </a>
  </p>
</BaseLayout>
