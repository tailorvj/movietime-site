---
export const prerender = false
import HebrewLayout from '../../../layouts/HebrewLayout.astro'
import BrandPaperSection from '../../../components/brand/BrandPaperSection.astro'
import { messages } from '../../../i18n'

const locale = 'he'
const t = messages(locale)
const { token } = Astro.params
---

<HebrewLayout
  locale={locale}
  variant="app"
  title={t.verify.pageTitle}
  metaDescription={t.verify.metaDescription}
>
  <BrandPaperSection center>
    <p id="verify-status" class="ih-body">{t.verify.loading}</p>
    <div id="verify-error" class="ih-hidden" role="alert">
      <h1 class="ih-callout">{t.verify.errorTitle}</h1>
      <p id="verify-error-text" class="ih-body"></p>
      <a href={`/${locale}`} class="ih-btn-primary" style="margin-top: 1.5rem;">
        {t.verify.back}
      </a>
    </div>
  </BrandPaperSection>
</HebrewLayout>

<script define:vars={{ token, locale, labels: t.verify, hiddenClass: 'ih-hidden' }}>
  const statusEl = document.getElementById('verify-status')
  const errorBox = document.getElementById('verify-error')
  const errorText = document.getElementById('verify-error-text')
  if (!statusEl || !errorBox || !errorText) throw new Error('verify page missing')

  let started = false

  function showError(kind) {
    statusEl.classList.add(hiddenClass)
    errorBox.classList.remove(hiddenClass)
    const map = {
      used: labels.errorUsed,
      expired: labels.errorExpired,
      invalid: labels.errorInvalid,
    }
    errorText.textContent = map[kind] ?? labels.errorInvalid
  }

  async function checkAuth() {
    const res = await fetch('/api/check-auth', { credentials: 'include' })
    const data = await res.json()
    if (data.authenticated) {
      window.location.replace(`/${data.locale ?? locale}/watch`)
      return true
    }
    return false
  }

  async function verify() {
    if (started || !token) {
      if (!token) showError('invalid')
      return
    }
    started = true

    try {
      const res = await fetch(`/api/verify-token/${token}`, {
        credentials: 'include',
      })
      const data = await res.json().catch(() => ({}))
      if (res.ok && data.ok) {
        sessionStorage.setItem('mt-watch-ready', '1')
        window.location.replace(`/${data.locale ?? locale}/watch`)
        return
      }
      if (data.error === 'token_already_used' || res.status === 409) {
        if (await checkAuth()) return
        showError('used')
        return
      }
      if (data.error === 'token_expired' || res.status === 410) {
        showError('expired')
        return
      }
      showError('invalid')
    } catch {
      showError('invalid')
    }
  }

  void verify()
</script>
