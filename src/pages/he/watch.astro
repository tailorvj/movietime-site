---
export const prerender = false
import HebrewLayout from '../../layouts/HebrewLayout.astro'
import BrandPaperSection from '../../components/brand/BrandPaperSection.astro'
import { messages } from '../../i18n'

const locale = 'he'
const t = messages(locale)
const videoId = import.meta.env.PUBLIC_VIMEO_VIDEO_ID ?? ''
const sessionTemplate = t.watch.sessionExpiringIn
---

<HebrewLayout
  locale={locale}
  variant="app"
  title={t.watch.pageTitle}
  metaDescription={t.watch.metaDescription}
  vimeoPreconnect={!!videoId}
>
  <BrandPaperSection>
    <div id="watch-loading">
      <p class="ih-body ih-muted">{t.watch.checking}</p>
    </div>

    <div id="watch-player" class="ih-hidden">
      <div class="ih-toolbar">
        <h1 class="ih-title">{t.watch.title}</h1>
        <button type="button" id="watch-logout" class="ih-btn-secondary">
          {t.watch.logout}
        </button>
      </div>
      <p id="watch-countdown" class="ih-muted"></p>
      {videoId ? (
        <div class="ih-video-frame">
          <iframe
            id="vimeo-frame"
            src={`https://player.vimeo.com/video/${videoId}?dnt=1`}
            title={t.watch.title}
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        </div>
      ) : (
        <p class="ih-alert">{t.watch.missingVideo}</p>
      )}
    </div>
  </BrandPaperSection>
</HebrewLayout>

<script define:vars={{ locale, sessionTemplate, homePath: `/${locale}`, hiddenClass: 'ih-hidden' }}>
  const loading = document.getElementById('watch-loading')
  const player = document.getElementById('watch-player')
  const countdown = document.getElementById('watch-countdown')
  const logoutBtn = document.getElementById('watch-logout')
  if (!loading || !player || !countdown || !logoutBtn) throw new Error('watch page missing')

  let expiresAt = null
  let tick = null

  function formatCountdown(seconds) {
    return sessionTemplate.replace('{{seconds}}', String(seconds))
  }

  function showPlayer() {
    loading.classList.add(hiddenClass)
    player.classList.remove(hiddenClass)
  }

  function startCountdown() {
    if (expiresAt === null) return
    const update = () => {
      const remaining = Math.max(0, Math.ceil((expiresAt - Date.now()) / 1000))
      countdown.textContent = formatCountdown(remaining)
      if (remaining <= 0) {
        void logout()
      }
    }
    update()
    tick = window.setInterval(update, 1000)
  }

  async function logout() {
    if (tick) window.clearInterval(tick)
    await fetch('/api/logout', { method: 'POST', credentials: 'include' })
    sessionStorage.removeItem('mt-watch-ready')
    window.location.replace(homePath)
  }

  async function ensureAuth() {
    const skipCheck = sessionStorage.getItem('mt-watch-ready') === '1'
    if (skipCheck) {
      sessionStorage.removeItem('mt-watch-ready')
      showPlayer()
      const res = await fetch('/api/check-auth', { credentials: 'include' })
      const data = await res.json()
      if (data.authenticated) {
        expiresAt = data.expiresAt
        startCountdown()
        return
      }
      window.location.replace(homePath)
      return
    }

    const res = await fetch('/api/check-auth', { credentials: 'include' })
    const data = await res.json()
    if (!data.authenticated) {
      window.location.replace(homePath)
      return
    }
    expiresAt = data.expiresAt
    showPlayer()
    startCountdown()
  }

  logoutBtn.addEventListener('click', () => void logout())
  void ensureAuth()
</script>
