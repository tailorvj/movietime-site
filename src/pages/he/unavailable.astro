---
export const prerender = true
import HebrewLayout from '../../layouts/HebrewLayout.astro'
import BrandPaperSection from '../../components/brand/BrandPaperSection.astro'
import { messages } from '../../i18n'

const locale = 'he'
const t = messages(locale)
const contact = import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'contact@example.com'
---

<HebrewLayout
  locale={locale}
  variant="app"
  title={t.unavailable.pageTitle}
  metaDescription={t.unavailable.metaDescription}
>
  <BrandPaperSection center>
    <h1 class="ih-title">{t.unavailable.title}</h1>
    <p class="ih-body">{t.unavailable.body}</p>
    <p style="margin-top: 1.5rem;">
      <a href={`mailto:${contact}`} class="ih-btn-primary">
        {t.unavailable.contact}
      </a>
    </p>
  </BrandPaperSection>
</HebrewLayout>
