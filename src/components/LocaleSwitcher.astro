---
import type { Locale } from '../i18n'
import { LOCALES } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const path = Astro.url.pathname.replace(/^\/(he|ru)/, '') || ''
---

<div class="flex gap-2 text-xs text-zinc-400">
  {
    LOCALES.map((code) => (
      <a
        href={`/${code}${path}`}
        class:list={[
          'hover:text-zinc-200',
          code === locale && 'font-semibold text-emerald-400',
        ]}
      >
        {code.toUpperCase()}
      </a>
    ))
  }
</div>
