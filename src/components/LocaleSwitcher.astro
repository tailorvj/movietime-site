---
import type { Locale } from '../i18n'
import { LOCALES } from '../i18n'

interface Props {
  locale: Locale
  variant?: 'dark' | 'light'
}

const { locale, variant = 'dark' } = Astro.props
const path = Astro.url.pathname.replace(/^\/(he|ru)/, '') || ''
const isLight = variant === 'light'
---

<div
  class:list={[
    'flex gap-2 text-xs',
    isLight ? 'text-slate-600' : 'text-zinc-400',
  ]}
>
  {
    LOCALES.map((code) => (
      <a
        href={`/${code}${path}`}
        class:list={[
          isLight ? 'hover:text-slate-900' : 'hover:text-zinc-200',
          code === locale &&
            (isLight ? 'font-semibold text-[#0370ba]' : 'font-semibold text-emerald-400'),
        ]}
      >
        {code.toUpperCase()}
      </a>
    ))
  }
</div>
