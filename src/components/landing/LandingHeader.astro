    class="landing-header__img"
    src={headerImg.src}
    width={headerImg.width}
    height={headerImg.height}
    alt="גט — המשפט של ויויאן אמסלם. הירשמו לצפייה מקוונת מאת ישראל חופשית. פרסי וולג'ין, גלובוס הזהב, TIFF, קאן ופרסי אופיר."
    fetchpriority="high"
  />
</section>
