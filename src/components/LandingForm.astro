---
import type { Locale } from '../i18n'
import { messages } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = messages(locale)
---

<h1 class="text-3xl font-semibold leading-tight sm:text-4xl">{t.landing.title}</h1>
<p class="mt-3 text-zinc-400">{t.landing.subtitle}</p>

<div
  id="landing-success"
  class="mt-8 hidden rounded-md border border-emerald-700/40 bg-emerald-950/40 p-4"
  role="status"
>
  <h2 class="text-lg font-semibold text-emerald-300">{t.landing.successTitle}</h2>
  <p class="mt-1 text-sm text-emerald-100/80">{t.landing.successBody}</p>
</div>

<form id="landing-form" class="mt-8 space-y-4" novalidate>
  <label class="block text-sm">
    <span class="block text-zinc-300">{t.landing.emailLabel}</span>
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      inputmode="email"
      dir="ltr"
      placeholder={t.landing.emailPlaceholder}
      class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100 focus:border-emerald-400 focus:outline-none"
    />
  </label>
  <p id="landing-error" class="hidden text-sm text-rose-400" role="alert"></p>
  <p class="text-xs text-zinc-500">{t.landing.privacyNote}</p>
  <button
    type="submit"
    id="landing-submit"
    class="w-full rounded-md bg-emerald-400 px-4 py-2.5 font-semibold text-black hover:bg-emerald-300 disabled:opacity-60"
  >
    {t.landing.submit}
  </button>
</form>

<script define:vars={{ locale, labels: t.landing }}>
  const form = document.getElementById('landing-form')
  const success = document.getElementById('landing-success')
  const errorEl = document.getElementById('landing-error')
  const submitBtn = document.getElementById('landing-submit')
  if (!form || !success || !errorEl || !submitBtn) throw new Error('landing form missing')

  let inFlight = false

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (inFlight) return
    inFlight = true
    errorEl.classList.add('hidden')
    submitBtn.disabled = true
    submitBtn.textContent = labels.submitting

    const email = new FormData(form).get('email')
    try {
      const res = await fetch('/api/request-access', {
        method: 'POST',
        credentials: 'include',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email, locale }),
      })
      const data = await res.json().catch(() => ({}))
      if (res.status === 202 || res.status === 200) {
        form.classList.add('hidden')
        success.classList.remove('hidden')
        return
      }
      const key =
        data.error === 'rate_limited'
          ? labels.errorRateLimit
          : data.error === 'invalid_input'
            ? labels.errorInvalidEmail
            : labels.errorGeneric
      errorEl.textContent = key
      errorEl.classList.remove('hidden')
    } catch {
      errorEl.textContent = labels.errorGeneric
      errorEl.classList.remove('hidden')
    } finally {
      inFlight = false
      submitBtn.disabled = false
      submitBtn.textContent = labels.submit
    }
  })
</script>
