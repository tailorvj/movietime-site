---
import type { Locale } from '../i18n'
import { messages } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = messages(locale)
---

<section class="landing-form-section" aria-labelledby="landing-form-heading">
  <div class="landing-form-section__inner">
    <h2 id="landing-form-heading" class="ih-sr-only">{t.landing.formHeading}</h2>

    <div id="landing-success" class="landing-form-success ih-hidden" role="status">
      <h2>{t.landing.successTitle}</h2>
      <p>{t.landing.successBody}</p>
    </div>

    <form id="landing-form" class="landing-form" novalidate>
      <div class="landing-form-row landing-form-row--split">
        <label>
          <span class="landing-field-label">{t.landing.nameLabel}</span>
          <input
            type="text"
            name="name"
            autocomplete="name"
            aria-describedby="landing-name-hint"
          />
        </label>
        <label>
          <span class="landing-field-label">{t.landing.phoneLabel}</span>
          <input
            type="tel"
            name="phone"
            autocomplete="tel"
            inputmode="tel"
            dir="ltr"
            aria-describedby="landing-phone-hint"
          />
        </label>
      </div>
      <p id="landing-name-hint" class="ih-sr-only">{t.landing.nameHint}</p>
      <p id="landing-phone-hint" class="ih-sr-only">{t.landing.phoneHint}</p>

      <div class="landing-form-row">
        <label>
          <span class="landing-field-label">{t.landing.emailLabel}</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            inputmode="email"
            dir="ltr"
            placeholder={t.landing.emailPlaceholder}
          />
        </label>
      </div>

      <label class="landing-form-consent">
        <input type="checkbox" name="marketing" value="yes" />
        <span>{t.landing.consentLabel}</span>
      </label>

      <p id="landing-error" class="landing-form-error ih-hidden" role="alert"></p>

      <button type="submit" id="landing-submit" class="landing-form-submit">
        {t.landing.submit}
      </button>

      <p class="landing-form-footnote">{t.landing.formFootnote}</p>
    </form>
  </div>
</section>

<script define:vars={{ locale, labels: t.landing }}>
  const hiddenClass = 'ih-hidden'
  const form = document.getElementById('landing-form')
  const success = document.getElementById('landing-success')
  const errorEl = document.getElementById('landing-error')
  const submitBtn = document.getElementById('landing-submit')
  if (!form || !success || !errorEl || !submitBtn) throw new Error('landing form missing')

  let inFlight = false

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (inFlight) return
    inFlight = true
    errorEl.classList.add(hiddenClass)
    submitBtn.disabled = true
    submitBtn.textContent = labels.submitting

    const email = new FormData(form).get('email')
    try {
      const res = await fetch('/api/request-access', {
        method: 'POST',
        credentials: 'include',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email, locale }),
      })
      const data = await res.json().catch(() => ({}))
      if (res.status === 202 || res.status === 200) {
        form.classList.add(hiddenClass)
        success.classList.remove(hiddenClass)
        return
      }
      const key =
        data.error === 'rate_limited'
          ? labels.errorRateLimit
          : data.error === 'invalid_input'
            ? labels.errorInvalidEmail
            : labels.errorGeneric
      errorEl.textContent = key
      errorEl.classList.remove(hiddenClass)
    } catch {
      errorEl.textContent = labels.errorGeneric
      errorEl.classList.remove(hiddenClass)
    } finally {
      inFlight = false
      submitBtn.disabled = false
      submitBtn.textContent = labels.submit
    }
  })
</script>
